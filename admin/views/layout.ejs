<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>MRF Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            navy:      { DEFAULT: '#060c18', mid: '#0a1628', light: '#0f2040' },
            gold:      { DEFAULT: '#c9a84c', light: '#d4b86a', dim: 'rgba(201,168,76,0.15)' },
            champagne: '#f5e6c8',
          },
          fontFamily: { sans: ['"Inter"', 'system-ui', 'sans-serif'] },
        },
      },
    };
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
  <style>
    :root {
      --gold: #c9a84c;
      --navy: #060c18;
    }
    body { background: #060c18; color: #c8d0dc; }
    .sidebar-link { @apply flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-slate-400 transition-colors duration-150 hover:text-champagne hover:bg-navy-light; }
    .sidebar-link.active { @apply text-gold bg-gold-dim; }
    input, textarea, select {
      background: rgba(255,255,255,0.04) !important;
      border: 1px solid rgba(255,255,255,0.1) !important;
      color: #f5e6c8 !important;
      border-radius: 8px;
      padding: 10px 14px;
      width: 100%;
      font-size: 0.92rem;
      transition: border-color 0.15s;
      outline: none;
    }
    input:focus, textarea:focus, select:focus {
      border-color: rgba(201,168,76,0.6) !important;
    }
    input::placeholder, textarea::placeholder { color: rgba(200,208,220,0.35); }
    label { display: block; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.09em; text-transform: uppercase; color: #7a8a9a; margin-bottom: 6px; }
    .btn-primary { background: #c9a84c; color: #060c18; font-weight: 700; padding: 10px 22px; border-radius: 8px; font-size: 0.88rem; cursor: pointer; border: none; transition: background 0.15s; letter-spacing: 0.02em; }
    .btn-primary:hover { background: #d4b86a; }
    .btn-secondary { background: rgba(255,255,255,0.06); color: #c8d0dc; font-weight: 600; padding: 10px 20px; border-radius: 8px; font-size: 0.88rem; cursor: pointer; border: 1px solid rgba(255,255,255,0.1); transition: all 0.15s; }
    .btn-secondary:hover { border-color: rgba(201,168,76,0.4); color: #c9a84c; }
    .btn-danger { background: rgba(239,68,68,0.1); color: #f87171; font-weight: 600; padding: 10px 20px; border-radius: 8px; font-size: 0.88rem; cursor: pointer; border: 1px solid rgba(239,68,68,0.25); transition: all 0.15s; }
    .btn-danger:hover { background: rgba(239,68,68,0.2); }
    .card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; }
    .badge-success { background: rgba(34,197,94,0.1); color: #4ade80; border: 1px solid rgba(34,197,94,0.2); padding: 2px 10px; border-radius: 99px; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; }
    .badge-error { background: rgba(239,68,68,0.1); color: #f87171; border: 1px solid rgba(239,68,68,0.2); padding: 2px 10px; border-radius: 99px; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; }
    .badge-pending { background: rgba(250,204,21,0.1); color: #fbbf24; border: 1px solid rgba(250,204,21,0.2); padding: 2px 10px; border-radius: 99px; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; }
    .toast { position: fixed; bottom: 24px; right: 24px; z-index: 9999; padding: 14px 22px; border-radius: 10px; font-size: 0.88rem; font-weight: 600; display: flex; align-items: center; gap: 10px; box-shadow: 0 8px 32px rgba(0,0,0,0.5); animation: slideUp 0.3s ease; }
    .toast-success { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); color: #4ade80; }
    .toast-error { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #f87171; }
    @keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    .divider { border: none; border-top: 1px solid rgba(255,255,255,0.07); margin: 20px 0; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #060c18; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 3px; }
  </style>
</head>
<body class="h-full font-sans antialiased">
<div class="flex h-full min-h-screen">

  <!-- Sidebar -->
  <aside class="w-60 flex-shrink-0 flex flex-col border-r border-white/[0.07] bg-navy-mid" style="background:#080f1e">
    <!-- Logo -->
    <div class="px-5 py-6 border-b border-white/[0.07]">
      <div class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-lg flex items-center justify-center" style="background:rgba(201,168,76,0.15)">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L10 6H14L11 9L12 13L8 11L4 13L5 9L2 6H6L8 2Z" fill="#c9a84c"/></svg>
        </div>
        <div>
          <div class="text-xs font-bold text-champagne tracking-wide">MRF Admin</div>
          <div class="text-xs text-slate-500 -mt-0.5">Resort Finder</div>
        </div>
      </div>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-3 py-4 space-y-0.5">
      <a href="/admin" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </a>
      <a href="/admin/hotels" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'hotels' ? 'active' : '' %>">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/></svg>
        Hotels
      </a>
      <a href="/admin/hotels/new" class="sidebar-link">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
        New Hotel
      </a>
      <div class="divider"></div>
      <a href="/admin/build" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'build' ? 'active' : '' %>">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        Build Site
      </a>
      <a href="/admin/audit" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'audit' ? 'active' : '' %>">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
        Audit Log
      </a>
    </nav>

    <!-- User + logout -->
    <div class="px-3 pb-4 border-t border-white/[0.07] pt-4">
      <div class="flex items-center gap-3 px-3 py-2 mb-2">
        <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold" style="background:rgba(201,168,76,0.2);color:#c9a84c">
          <%= username ? username.charAt(0).toUpperCase() : 'A' %>
        </div>
        <div class="text-sm font-medium text-champagne truncate"><%= username || 'Admin' %></div>
      </div>
      <form action="/admin/logout" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="sidebar-link w-full text-red-400 hover:text-red-300 hover:bg-red-500/10">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Logout
        </button>
      </form>
    </div>
  </aside>

  <!-- Main -->
  <div class="flex-1 flex flex-col min-w-0 overflow-auto">
    <main class="flex-1 p-8">
      <%- body %>
    </main>
  </div>
</div>

<!-- Toast -->
<% if (locals.flash) { %>
<div class="toast toast-<%= flash.type === 'success' ? 'success' : 'error' %>" id="toast">
  <% if (flash.type === 'success') { %><span>✓</span><% } else { %><span>✗</span><% } %>
  <%= flash.message %>
</div>
<script>setTimeout(() => { const t = document.getElementById('toast'); if (t) t.style.opacity = '0'; }, 4000);</script>
<% } %>

</body>
</html>
