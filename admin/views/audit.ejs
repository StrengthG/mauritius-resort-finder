<%
  title = 'Audit Log';
  activePage = 'audit';
%>

<div class="mb-8">
  <h1 class="text-2xl font-bold text-champagne">Audit Log</h1>
  <p class="text-slate-500 text-sm mt-1"><%= total %> total entries</p>
</div>

<div class="card overflow-hidden">
  <% if (entries.length === 0) { %>
  <div class="p-12 text-center text-slate-600">No audit entries yet.</div>
  <% } else { %>
  <table style="width:100%;border-collapse:collapse">
    <thead>
      <tr style="border-bottom:1px solid rgba(255,255,255,0.07)">
        <th style="text-align:left;padding:12px 20px;font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#6b7a8d">Time</th>
        <th style="text-align:left;padding:12px 16px;font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#6b7a8d">User</th>
        <th style="text-align:left;padding:12px 16px;font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#6b7a8d">Action</th>
        <th style="text-align:left;padding:12px 16px;font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#6b7a8d">Detail</th>
        <th style="text-align:left;padding:12px 16px;font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#6b7a8d">IP</th>
      </tr>
    </thead>
    <tbody>
      <% entries.forEach(entry => { %>
      <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
        <td style="padding:12px 20px;font-size:0.78rem;color:#6b7a8d;white-space:nowrap"><%= new Date(entry.created_at).toLocaleString() %></td>
        <td style="padding:12px 16px;font-size:0.84rem;color:#c8d0dc;font-weight:500"><%= entry.username %></td>
        <td style="padding:12px 16px">
          <span class="font-mono text-xs px-2 py-0.5 rounded" style="background:rgba(255,255,255,0.05);color:<%= entry.action.includes('DELETE') ? '#f87171' : entry.action.includes('LOGIN') && !entry.action.includes('FAILED') ? '#4ade80' : entry.action.includes('FAILED') ? '#fbbf24' : '#7a8a9a' %>"><%= entry.action %></span>
        </td>
        <td style="padding:12px 16px;font-size:0.82rem;color:#7a8a9a;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= entry.detail || '—' %></td>
        <td style="padding:12px 16px;font-size:0.78rem;color:#4a5568;font-family:monospace"><%= entry.ip_address || '—' %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</div>

<!-- Pagination -->
<% if (total > perPage) { %>
<div class="flex items-center justify-between mt-5">
  <p class="text-xs text-slate-500">Page <%= page %> of <%= Math.ceil(total / perPage) %></p>
  <div class="flex gap-2">
    <% if (page > 1) { %>
    <a href="?page=<%= page - 1 %>" class="btn-secondary" style="padding:7px 16px;font-size:0.82rem">← Prev</a>
    <% } %>
    <% if (page * perPage < total) { %>
    <a href="?page=<%= page + 1 %>" class="btn-secondary" style="padding:7px 16px;font-size:0.82rem">Next →</a>
    <% } %>
  </div>
</div>
<% } %>
