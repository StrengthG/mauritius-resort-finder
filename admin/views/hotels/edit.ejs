<%
  title = hotel && hotel.id ? 'Edit Hotel' : 'New Hotel';
  activePage = 'hotels';
%>

<div class="flex items-center gap-4 mb-8">
  <a href="/admin/hotels" class="text-slate-500 hover:text-slate-400 transition-colors">
    <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
  </a>
  <div>
    <h1 class="text-2xl font-bold text-champagne"><%= hotel && hotel.id ? hotel.name : 'New Hotel' %></h1>
    <p class="text-slate-500 text-sm mt-0.5"><%= hotel && hotel.id ? 'Edit hotel details' : 'Add a new hotel to the admin database' %></p>
  </div>
</div>

<!-- Errors -->
<% if (errors && errors.length) { %>
<div class="mb-6 px-5 py-4 rounded-xl" style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2)">
  <p class="text-red-400 font-semibold text-sm mb-1">Please fix the following:</p>
  <ul class="list-disc pl-4 space-y-1">
    <% errors.forEach(e => { %><li class="text-red-400 text-sm"><%= e %></li><% }); %>
  </ul>
</div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- Main form -->
  <div class="lg:col-span-2 space-y-6">
    <div class="card p-6">
      <h2 class="text-sm font-bold text-champagne uppercase tracking-wide mb-5">Hotel Details</h2>
      <form action="<%= hotel && hotel.id ? '/admin/hotels/' + hotel.id : '/admin/hotels' %>" method="POST" id="hotelForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          <div class="sm:col-span-2">
            <label for="name">Hotel Name *</label>
            <input type="text" id="name" name="name" value="<%= hotel && hotel.name ? hotel.name : '' %>" placeholder="e.g. Royal Palm Beachcomber Luxury" required />
          </div>
          <div>
            <label for="region">Region</label>
            <input type="text" id="region" name="region" value="<%= hotel && hotel.region ? hotel.region : '' %>" placeholder="e.g. Grand Baie" />
          </div>
          <div>
            <label for="location">Location Detail</label>
            <input type="text" id="location" name="location" value="<%= hotel && hotel.location ? hotel.location : '' %>" placeholder="e.g. North Coast" />
          </div>
          <div>
            <label for="star_rating">Star Rating</label>
            <select id="star_rating" name="star_rating">
              <% [5,4,3].forEach(s => { %>
              <option value="<%= s %>" <%= hotel && Number(hotel.star_rating) === s ? 'selected' : '' %>><%= s %> Stars</option>
              <% }); %>
            </select>
          </div>
          <div>
            <label for="price_per_night_usd">Price per Night (USD)</label>
            <input type="number" id="price_per_night_usd" name="price_per_night_usd" value="<%= hotel && hotel.price_per_night_usd ? hotel.price_per_night_usd : '' %>" placeholder="e.g. 850" min="0" step="10" />
          </div>
        </div>

        <div class="mb-4">
          <label for="affiliate_url">Affiliate URL</label>
          <input type="url" id="affiliate_url" name="affiliate_url" value="<%= hotel && hotel.affiliate_url ? hotel.affiliate_url : '' %>" placeholder="https://expedia.com/affiliate/XXXXXXX" />
          <p class="text-xs text-slate-600 mt-2">Expedia Creator Hub affiliate link for this hotel.</p>
        </div>

        <div class="mb-5">
          <label for="description_override">Description Override <span style="text-transform:none;letter-spacing:0;font-weight:400;color:#4a5568">(optional)</span></label>
          <textarea id="description_override" name="description_override" rows="4" placeholder="Optional editorial description that overrides the AI-generated one at build time."><%= hotel && hotel.description_override ? hotel.description_override : '' %></textarea>
        </div>

        <button type="submit" class="btn-primary"><%= hotel && hotel.id ? 'Save Changes' : 'Create Hotel' %></button>
      </form>
    </div>
  </div>

  <!-- Image management sidebar -->
  <div class="space-y-5">

    <% if (hotel && hotel.id) { %>
    <!-- Existing images -->
    <div class="card p-5">
      <h2 class="text-sm font-bold text-champagne uppercase tracking-wide mb-4">
        Images <span class="text-slate-500 font-normal normal-case"><%= images.length %>/5</span>
      </h2>

      <% if (images && images.length) { %>
      <div id="imageList" class="space-y-2 mb-4">
        <% images.forEach(img => { %>
        <div class="flex items-center gap-3 p-2 rounded-lg" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06)" data-id="<%= img.id %>">
          <div class="w-14 h-10 rounded overflow-hidden flex-shrink-0">
            <img src="/admin/uploads/<%= hotel.id %>/<%= img.filename %>" alt="<%= img.alt_text || '' %>" class="w-full h-full object-cover" />
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs text-slate-400 truncate"><%= img.filename %></p>
            <p class="text-xs text-slate-600">Order: <%= img.display_order %></p>
          </div>
          <form action="/admin/hotels/<%= hotel.id %>/images/<%= img.id %>/delete" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="text-slate-500 hover:text-red-400 transition-colors" title="Delete image">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
          </form>
        </div>
        <% }); %>
      </div>
      <% } else { %>
      <div class="text-center py-6 mb-4" style="border:2px dashed rgba(255,255,255,0.08);border-radius:10px">
        <p class="text-slate-600 text-sm">No images yet</p>
      </div>
      <% } %>

      <% if (images.length < 5) { %>
      <!-- Upload form -->
      <form action="/admin/hotels/<%= hotel.id %>/images" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label for="images" id="dropZone" class="block cursor-pointer text-center p-4 rounded-xl transition-colors" style="border:2px dashed rgba(201,168,76,0.3);border-radius:10px">
          <input type="file" id="images" name="images" accept=".jpg,.jpeg,.png,.webp" multiple class="hidden" onchange="updateFileLabel(this)" />
          <svg class="mx-auto mb-2 text-gold" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          <p class="text-xs text-gold font-semibold mb-1">Click to upload</p>
          <p id="fileLabel" class="text-xs text-slate-600">JPG, PNG, WebP · Max <%= 5 - images.length %> more · 10 MB each</p>
        </label>
        <button type="submit" class="btn-secondary w-full mt-3" style="font-size:0.82rem;padding:9px">Upload Images</button>
      </form>
      <% } else { %>
      <p class="text-xs text-slate-500 text-center">Maximum 5 images reached. Delete one to upload more.</p>
      <% } %>
    </div>

    <!-- Preview links -->
    <div class="card p-5">
      <h2 class="text-sm font-bold text-champagne uppercase tracking-wide mb-3">Preview</h2>
      <div class="space-y-2">
        <a href="https://mauritiusresortfinder.com/hotels/<%= hotel.slug %>/" target="_blank" class="flex items-center gap-2 text-sm text-slate-400 hover:text-gold transition-colors">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Hotel detail page
        </a>
        <a href="https://mauritiusresortfinder.com" target="_blank" class="flex items-center gap-2 text-sm text-slate-400 hover:text-gold transition-colors">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Homepage rankings
        </a>
      </div>
    </div>
    <% } else { %>
    <div class="card p-5" style="border-color:rgba(201,168,76,0.15)">
      <p class="text-xs text-slate-500 text-center">Save the hotel first, then you can upload images.</p>
    </div>
    <% } %>

  </div>
</div>

<script>
function updateFileLabel(input) {
  const label = document.getElementById('fileLabel');
  if (input.files.length > 0) {
    label.textContent = input.files.length + ' file(s) selected';
    label.style.color = '#c9a84c';
  }
}

// Drag & drop styling
const zone = document.getElementById('dropZone');
if (zone) {
  zone.addEventListener('dragover', e => { e.preventDefault(); zone.style.borderColor = 'rgba(201,168,76,0.7)'; });
  zone.addEventListener('dragleave', () => { zone.style.borderColor = 'rgba(201,168,76,0.3)'; });
  zone.addEventListener('drop', e => {
    e.preventDefault();
    zone.style.borderColor = 'rgba(201,168,76,0.3)';
    const fi = document.getElementById('images');
    fi.files = e.dataTransfer.files;
    updateFileLabel(fi);
  });
}
</script>
