{
  "name": "mauritius-resort-finder",
  "version": "1.0.0",
  "description": "AI-powered hotel and resort affiliate platform for Mauritius — static site generator with scoring, explanation, and Airtable CMS integration.",
  "main": "site_builder.js",
  "scripts": {
    "test": "node run_tests.js",
    "test:scoring": "node scoring_engine.test.js",
    "test:phrases": "echo 'phrase_library has no standalone test suite'",
    "test:hallucination": "node hallucination_guard.test.js",
    "test:confidence": "node confidence_enforcer.test.js",
    "test:explanation": "node explanation_engine.test.js",
    "test:assembler": "node block_assembler.test.js",
    "test:renderer": "node static_page_renderer.test.js",
    "test:sync": "node airtable_sync.test.js",
    "test:builder": "node site_builder.test.js",
    "test:admin": "node admin/admin.test.js",
    "build": "node site_builder.js",
    "sync": "node airtable_sync.js --out ./data",
    "start": "node site_builder.js --verbose",
    "admin": "node admin/server.js",
    "setup-admin": "node admin/setup.js",
    "seed-admin": "node admin/seed-hotels.js"
  },
  "keywords": [
    "mauritius",
    "hotels",
    "resorts",
    "affiliate",
    "static-site-generator",
    "airtable",
    "cloudflare-pages",
    "seo"
  ],
  "author": "Mauritius Resort Finder",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_GITHUB_USERNAME/mauritius-resort-finder.git"
  },
  "homepage": "https://mauritiusresortfinder.com",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-sqlite3": "^0.9.16",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "method-override": "^3.0.0",
    "multer": "^2.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "supertest": "^7.2.2"
  }
}
