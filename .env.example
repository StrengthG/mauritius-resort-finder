# ─── Airtable (optional — used by airtable_sync.js) ──────────────────────────
AIRTABLE_API_KEY=your_token_here
AIRTABLE_BASE_ID=appkEOiXVC89MR5DN

# ─── Admin Dashboard ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Port the admin server listens on (default: 3001; Railway sets PORT automatically)
ADMIN_PORT=3001

# ─── Production build (required in production) ────────────────────────────────
# GitHub personal access token with repo write scope
GITHUB_TOKEN=ghp_your_token_here
# Repository in "owner/repo" format, e.g. "StrengthG/mauritius-resort-finder"
GITHUB_REPO=StrengthG/mauritius-resort-finder
# Branch to commit to (default: main)
GITHUB_BRANCH=main
# Optional: Cloudflare Pages deploy hook URL (triggers immediate build)
CLOUDFLARE_DEPLOY_HOOK_URL=

# ─── Contact form (Cloudflare Pages env vars — set in CF dashboard) ───────────
# Sign up at resend.com, verify mauritiusresortfinder.com domain, get API key
RESEND_API_KEY=re_your_api_key_here
# Sender address — must be on a domain verified in Resend
EMAIL_FROM=noreply@mauritiusresortfinder.com
# Recipient for all contact form submissions
CONTACT_EMAIL=strengthygivenncube@gmail.com
